---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import { tagLabel } from '@/lib/tags';

const products = (await getCollection('software')).sort(
  (a, b) => (a.data.feature_with_priority ?? 99) - (b.data.feature_with_priority ?? 99),
);
---

<BaseLayout title="Software" description="Open-source software developed with Ribose's cooperation.">
  <PageHero
    eyebrow="Index — Software"
    title="Software"
    description="Open-source software developed with Ribose's cooperation."
  />

  <section class="mx-auto w-full max-w-6xl px-6 py-16 md:py-20">
    <div class="grid gap-5 md:grid-cols-2">
      {
        products.map((p) => (
          <a href={`/software/${p.id}/`} class="card card-hover group block p-6">
            <div class="flex items-start justify-between gap-4">
              <h2 class="font-sans text-2xl font-bold transition-colors group-hover:text-accent">
                {p.data.title}
              </h2>
              <span
                class="text-faint transition-all group-hover:translate-x-0.5 group-hover:text-accent"
                aria-hidden="true"
              >
                →
              </span>
            </div>
            <p class="mt-2 leading-relaxed text-muted">{p.data.description}</p>
            {p.data.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {p.data.tags.map((tag) => (
                  <span class="rounded-full border border-line bg-surface-dim px-2.5 py-0.5 font-mono text-xs text-muted">
                    {tagLabel(tag)}
                  </span>
                ))}
              </div>
            )}
            {p.data.external_links.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-x-4 gap-y-1 border-t border-line pt-4">
                {p.data.external_links.map((link) => (
                  <span class="font-mono text-xs text-accent underline decoration-accent/30 underline-offset-4">
                    {link.title}
                  </span>
                ))}
              </div>
            )}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

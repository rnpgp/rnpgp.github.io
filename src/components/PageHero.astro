---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}
const { eyebrow, title, description } = Astro.props;
---

<header class="page-hero-bg relative overflow-hidden border-b border-line">
  <div class="mx-auto w-full max-w-6xl px-6 pb-12 pt-28 md:pb-16 md:pt-32">
    <p class="mono-label">{eyebrow}</p>
    <h1 class="mt-3 font-sans text-4xl font-bold tracking-tight md:text-5xl">{title}</h1>
    {description && <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">{description}</p>}
    <hr class="gradient-rule mt-8 w-24" />
    <slot />
  </div>
</header>

---
import SymbolLogo from './brand/SymbolLogo.astro';
import Wordmark from './brand/Wordmark.astro';

const year = new Date().getFullYear();

const columns = [
  {
    label: 'Software',
    links: [
      { href: '/software/rnp/', label: 'RNP' },
      { href: '/software/py-rnp/', label: 'Py-RNP' },
      { href: '/software/ruby-rnp/', label: 'Ruby-RNP' },
      { href: '/software/homebrew-rnp/', label: 'homebrew-rnp' },
      { href: '/software/', label: 'All software' },
    ],
  },
  {
    label: 'Project',
    links: [
      { href: '/about/', label: 'About' },
      { href: '/blog/', label: 'Blog' },
      { href: '/specs/', label: 'Specifications' },
      { href: '/contribute/', label: 'Contribute' },
      { href: '/feedback/', label: 'Feedback' },
    ],
  },
  {
    label: 'Resources',
    links: [
      { href: '/docs/', label: 'Manual' },
      { href: '/advisories/', label: 'Security advisories' },
      { href: '/openpgp-keys/', label: 'OpenPGP keys' },
      { href: '/rss.xml', label: 'RSS feed' },
      { href: 'https://www.ribose.com/tos', label: 'Terms of service', external: true },
      { href: 'https://www.ribose.com/privacy', label: 'Privacy policy', external: true },
    ],
  },
];
---

<footer class="mt-auto bg-[#0c1024] text-[#a8aec9]">
  <div class="gradient-rule"></div>
  <div class="mx-auto w-full max-w-6xl px-6 py-14">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-5">
      <div class="col-span-2">
        <a href="/" class="flex items-center gap-2.5 text-white" aria-label="RNP home">
          <SymbolLogo class="h-7 w-auto" />
          <Wordmark class="h-6 w-auto" />
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed">
          Powering end-to-end email encryption in
          <a
            href="https://www.thunderbird.net/"
            class="underline decoration-white/40 underline-offset-4 transition-colors hover:text-white"
            >Mozilla Thunderbird</a
          >. LibrePGP secure.
        </p>
        <div class="mt-5 flex items-center gap-4">
          <a
            href="https://github.com/rnpgp/rnp"
            class="text-[#a8aec9] transition-colors hover:text-white"
            aria-label="RNP on GitHub"
          >
            <svg viewBox="0 0 16 16" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path
                d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"
              ></path>
            </svg>
          </a>
          <a
            href="https://twitter.com/RiboseUS"
            class="text-[#a8aec9] transition-colors hover:text-white"
            aria-label="Ribose on X / Twitter"
          >
            <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="currentColor" aria-hidden="true">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
      {
        columns.map((col) => (
          <div>
            <h3 class="mono-label text-[#5f6788]">{col.label}</h3>
            <ul class="mt-4 space-y-2.5 text-sm">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="transition-colors hover:text-white"
                    {...(link.external ? { rel: 'noopener' } : {})}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div
      class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-white/10 pt-6 text-xs sm:flex-row sm:items-center"
    >
      <p>Copyright © {year} Ribose Group Inc. — All rights reserved.</p>
      <p class="font-mono tracking-wide">
        RNP is developed by{' '}
        <a
          href="https://open.ribose.com/"
          class="underline decoration-white/30 underline-offset-4 transition-colors hover:text-white"
          >Ribose</a
        >
      </p>
    </div>
  </div>
</footer>
